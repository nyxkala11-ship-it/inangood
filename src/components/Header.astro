        margin-top: 10px;
        background-color: rgb(0, 225, 255);
        border-radius: 5px;
    }
    .drophover {
        display: inline-block;
        float: left;
        overflow: auto;
    }
    .dropdown {
        display: none;
        z-index: 999;
    }
    .drophover:hover {
        background-color: aquamarine;
    }
    .drophover:hover .dropdown{
        margin-top: 8pt;
        margin-left: -8pt;
        display: block;
        overflow: auto;
        position: absolute;
        max-width: 350px;
        background-color: aliceblue;
        padding: 15px;
        border-radius: 5px;
    }
    card {
        width: 125px;
    }
    #MenuSearch[type=text] {
    float: right;
    padding: 8px;
    padding-left: 16px;
    border: none;
    margin-top: 8px;
    margin-right: 16px;
    font-size: 17px;
    background-color: aliceblue;
    margin: 10px;
    
    right: 0;
    max-lines: 1;
    height: 2.5rem;
    width: 350px;
    }
    
    #header{
