        padding: 15px;
        width: 1440px;
        max-width: 100%;
        color: aliceblue;
    }
    .menu-header {
        background-color: #f191a6;
        width: 1440px;
        max-width: 100%;
    }
    /*Strip the ul of padding and list styling*/
    ul {
