---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
import introbackground from '../assets/intro/advicesbackground.png';

import Material from '../components/Material.astro';
// Lucide icons
import { CircleCheckBig, Layers, ClockCheck } from '@lucide/astro';
import { Printer } from '@lucide/astro';

---

<div class="flex flex-col" id="container">
	<!--<img id="background" src={background.src} alt="" fetchpriority="high" />-->
	<main>

	<div id="intro">

		<p id="XI">XƯỞNG IN</p>
		<h1 id="intro-title">TÚI GIẤY KRAFT<br>& TÚI NỀN MÀU</h1>
		<div id="red-intro"><p>GIÁ GỐC - NHẬN TỪ 50 TÚI</p></div>
		<p id="intro-h2">CÓ HÀNG TRONG NGÀY</p>

		<div class="grid grid-cols-5">
			<ul id="intro-list" class="col-span-2">

		<li class="items-start grid grid-cols-10">
		<CircleCheckBig size={44} />
		<p style="padding: 0; padding-left: 1rem; padding-bottom: 2rem;" class="col-span-9"> Cần in túi giấy để kịp bán hàng</p>
		</li>

		<li class="items-start grid grid-cols-10">
		<Printer size={44} />
		<p style="padding: 0; padding-left: 1rem; padding-bottom: 2rem;" class="col-span-9"> Xưởng in trực tiếp - làm nhanh, lấy liền, không cần số lượng lớn.</p>
		</li>
		
		<li class="items-start grid grid-cols-10">
		<Layers style="display: block;" size={44} />
		<p style="padding: 0; padding-left: 1rem; padding-bottom: 2rem;" class="col-span-9"> Chỉ từ 50 túi, bạn đã có túi giấy in logo riêng - 
			phù hợp shop mới, bán online hoặc test thị trường.</p>
		</li>

		<div class="items-start grid grid-cols-10">
		<ClockCheck style="display: inline-block;" size={44} />
		<p style="padding: 0; padding-left: 1rem; padding-bottom: 2rem;" class="col-span-9"> Ngoài ra, xưởng nhận in trọn bộ: Hóa đơn,
			 tem nhãn, tag treo, voucher, menu, bao bì đóng gói
			  -> giúp bạn có bộ nhận diện đồng bộ, bán chuyên nghiệp hơn.</p>
		</div>
	
	</ul>
	</div>
	</main>
	
	<Material />
	<!--
		<a href="https://astro.build/blog/astro-6-beta/" id="news" class="box">
		<p>Phần class box có thể dùng Chat hỗ trợ!</p>
	</a>
	-->
</div>

<style>

	#intro-list p {
		padding: 1rem;
		padding-left: 2rem;
		font-size: 1.5rem;
		line-height: 1.5rem;
	}
	#intro-h2 {
		font-size: 2rem !important;
		color: #781722 !important;
		padding: 1rem; 
		padding-left: 1.5rem;
		margin-top: 0.5rem;
		margin-bottom: 2rem;
	}
	#red-intro {
		background-color: #781722;
		padding: 5px;
		margin-top: 1.5rem;
		border-radius: 20px;
		position: relative;
		display: inline-block;
		line-height: 2rem;
	}
	#red-intro p {
		color: white;
		padding-left: 1.2rem;
		padding-right: 1.2rem;
		padding-top: 0.9rem;
		padding-bottom: 0.7rem;
		font-size: 2rem;
	}
	#intro-title {
		color: #781722 !important;
		font-size: 5rem !important;
		font-family: Tahoma, sans-serif !important;
		font-weight: 800;
		line-height: 5rem;
	}
	#XI {
		color: #717171;
		font-size: 2rem;
		font-weight: 600;
	}
	#intro {
		padding: 2rem;
	}
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		padding-top: 1.2em;
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
		align-items: center;
	}

	main {
		height: 100%;
		display: flex;
		justify-content: center;
		max-width: 1440px;
		background-image: url("../assets/intro/advicesbackground.png");
		background-size: auto 100%;
		background-repeat: no-repeat;
		background-attachment: inherit;
		background-position: right;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		padding: 16px;
	}

	h1 {
		margin-top: 0.25em;
	}

	#links {
		display: flex;
		gap: 16px;
	}

	#links a {
		display: flex;
		align-items: center;
		padding: 10px 12px;
		color: #111827;
		text-decoration: none;
		transition: color 0.2s;
	}

	#links a:hover {
		color: rgb(78, 80, 86);
	}

	#links a svg {
		height: 1em;
		margin-left: 8px;
	}

	#links a.button {
		color: white;
		background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.12),
			inset 0 -2px 0 rgba(0, 0, 0, 0.24);
		border-radius: 10px;
	}

	#links a.button:hover {
		color: rgb(230, 230, 230);
		box-shadow: none;
	}

	pre {
		font-family:
			ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono',
			monospace;
		font-weight: normal;
		background: linear-gradient(14deg, #d83333 0%, #f041ff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0;
	}

	h2 {
		margin: 0 0 1em;
		font-weight: normal;
		color: #111827;
	}

	p {
		color: #4b5563;
		line-height: 24px;
		letter-spacing: -0.006em;
		margin: 0;
	}

	code {
		display: inline-block;
		background:
			linear-gradient(66.77deg, #f3cddd 0%, #f5cee7 100%) padding-box,
			linear-gradient(155deg, #d83333 0%, #f041ff 18%, #f5cee7 45%) border-box;
		border-radius: 8px;
		border: 1px solid transparent;
		padding: 6px 8px;
	}

	.box {
		padding: 16px;
		background: rgba(255, 255, 255, 1);
		border-radius: 16px;
		border: 1px solid white;
	}

	#news {
		position: absolute;
		bottom: 16px;
		right: 16px;
		max-width: 300px;
		text-decoration: none;
		transition: background 0.2s;
		backdrop-filter: blur(50px);
	}

	#news:hover {
		background: rgba(255, 255, 255, 0.55);
	}

	@media screen and (max-height: 368px) {
		#news {
			display: none;
		}
	}

	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
		}

		#hero {
			display: block;
			padding-top: 10%;
		}

		#links {
			flex-wrap: wrap;
		}

		#links a.button {
			padding: 14px 18px;
		}

		#news {
			right: 16px;
			left: 16px;
			bottom: 2.5rem;
			max-width: 100%;
		}

		h1 {
			line-height: 1.5;
		}
	}
</style>
